<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="315" android:startColor="@color/action_button_start" android:endColor="@color/action_button_end" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient android:angle="315" android:startColor="#F7FBFF" android:endColor="@color/action_button_inner" />
            <corners android:radius="23dp" />
            <stroke android:width="1dp" android:color="@color/action_button_stroke" />
        </shape>
    </item>
</layer-list>
