<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="@color/app_background_top"
                android:centerColor="@color/app_background_mid"
                android:endColor="@color/app_background_bottom" />
        </shape>
    </item>
    <item android:top="-120dp" android:right="-80dp" android:gravity="top|end">
        <shape android:shape="oval">
            <size android:width="260dp" android:height="260dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="130dp"
                android:startColor="#26FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>
    <item android:left="-120dp" android:bottom="-140dp" android:gravity="bottom|start">
        <shape android:shape="oval">
            <size android:width="300dp" android:height="300dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="150dp"
                android:startColor="#18007BFF"
                android:endColor="#00007BFF"/>
        </shape>
    </item>
</layer-list>
