<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <size android:width="58dp" android:height="58dp" />
            <gradient android:angle="315" android:startColor="#6CB4FF" android:endColor="#3B78FF" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="oval">
            <size android:width="56dp" android:height="56dp" />
            <gradient android:angle="270" android:startColor="#33FFFFFF" android:endColor="#00FFFFFF" />
            <stroke android:width="1dp" android:color="#28FFFFFF" />
        </shape>
    </item>
</layer-list>
