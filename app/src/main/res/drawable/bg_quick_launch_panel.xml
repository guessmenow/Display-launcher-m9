<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#F7FAFF"
                android:centerColor="#EEF4FF"
                android:endColor="#E8F1FF" />
            <corners android:radius="22dp" />
            <stroke android:width="1dp" android:color="#D7E0EF" />
        </shape>
    </item>
    <item android:gravity="top|end" android:top="-16dp" android:right="-12dp">
        <shape android:shape="oval">
            <size android:width="120dp" android:height="120dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="60dp"
                android:startColor="#1A5F8CFF"
                android:endColor="#005F8CFF" />
        </shape>
    </item>
</layer-list>
