<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#2149C8FF"
                android:centerColor="#1E6EFF"
                android:endColor="#3D2F8F" />
            <corners android:radius="28dp" />
            <stroke android:width="1dp" android:color="#44FFFFFF" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#AA103267"
                android:centerColor="#66194893"
                android:endColor="#88101F42" />
            <corners android:radius="27dp" />
        </shape>
    </item>
    <item android:gravity="top|end" android:top="-18dp" android:right="-10dp">
        <shape android:shape="oval">
            <size android:width="120dp" android:height="120dp" />
            <gradient android:type="radial" android:gradientRadius="60dp" android:centerX="0.5" android:centerY="0.5" android:startColor="#66FFFFFF" android:endColor="#00FFFFFF"/>
        </shape>
    </item>
</layer-list>
